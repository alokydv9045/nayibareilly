{
  "name": "nayibareilly-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch ./src/server.js",
    "start": "node ./src/server.js",
    "build": "npx prisma generate",
    "render:build": "npm ci && npx prisma generate && npx prisma migrate deploy",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "seed:admin": "node ./scripts/seed-admin-prisma.js",
    "seed:realistic": "node ./scripts/seed-realistic-data.js",
    "seed": "node ./scripts/seed-realistic-data.js"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.686.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.50.0",
    "@opentelemetry/sdk-metrics": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.50.0",
    "@prisma/client": "^6.16.2",
    "@prisma/instrumentation": "^6.16.2",
    "@sentry/node": "^10.56.0",
    "@sentry/profiling-node": "^10.56.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "http-errors": "^2.0.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pino": "^9.3.0",
    "pino-http": "^9.0.0",
    "prisma": "^6.16.2",
    "rate-limit-redis": "^4.2.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2"
  }
}
