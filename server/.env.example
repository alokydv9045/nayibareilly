# ================================================
# NayiBareilly Server Environment Configuration
# ================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!
# ================================================

# ==========================================
# 1. NODE ENVIRONMENT
# ==========================================
NODE_ENV=development
# Options: development | production | test

# ==========================================
# 2. SERVER CONFIGURATION
# ==========================================
PORT=4001
# Port for the API server (default: 4001)

CLIENT_ORIGIN=http://localhost:3000
# Frontend URL(s) - comma-separated for multiple domains
# Example: https://yourdomain.com,https://www.yourdomain.com
# Development: http://localhost:3000

API_VERSION=1.0.0
# API version for tracking

# ==========================================
# 3. DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres:1234@localhost:5432/Nayibareilly
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://nayibareilly:secure_pass@localhost:5432/nayibareilly

# Optional: Connection pool settings
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# ==========================================
# 4. JWT AUTHENTICATION (CRITICAL - MUST BE 32+ CHARACTERS!)
# ==========================================

# Generate secrets with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_this_immediately
# Main JWT signing secret (MUST be 32+ characters)

JWT_REFRESH_SECRET=your_refresh_token_secret_key_minimum_32_characters_long_change_this_now
# Refresh token signing secret (MUST be 32+ characters)

JWT_EXPIRES_IN=1h
# Access token expiration (e.g., 1h, 15m, 2d)

JWT_REFRESH_EXPIRES_IN=7d
# Refresh token expiration (e.g., 7d, 30d)

REFRESH_TOKEN_HASH_SECRET=your_refresh_token_hmac_secret_minimum_32_characters_long_change_this
# HMAC secret for refresh token hashing (MUST be 32+ characters)

REFRESH_GRACE_WINDOW_MS=5000
# Grace period for token refresh (milliseconds)

REFRESH_RECENT_ROTATIONS_TTL_MS=60000
# TTL for tracking recent token rotations (milliseconds)

# ==========================================
# 5. FIREBASE CONFIGURATION
# ==========================================

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# Firebase Storage bucket name (from Firebase Console)

# Firebase Service Account (JSON)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk"}
# Complete Firebase service account JSON (from Firebase Console)
# Alternative: Save JSON file as server/firebase-service-account.json

# Firebase Cloud Messaging (FCM)
FIREBASE_SERVER_KEY=your_firebase_cloud_messaging_server_key
# FCM Server Key for push notifications (from Firebase Console > Cloud Messaging)

# ==========================================
# 6. EMAIL CONFIGURATION
# ==========================================

EMAIL_HOST=smtp.gmail.com
# SMTP server hostname
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
# Custom: mail.yourdomain.com

EMAIL_PORT=587
# SMTP port (587 for TLS, 465 for SSL)

EMAIL_SECURE=false
# Use SSL (true for port 465, false for port 587)

EMAIL_USER=your-email@gmail.com
# Email account username
# For Gmail: Use app-specific password (not your regular password)

EMAIL_PASSWORD=your_app_specific_password
# Email account password or app-specific password
# Gmail: Generate at https://myaccount.google.com/apppasswords

EMAIL_FROM=noreply@nayibareilly.gov.in
# "From" email address for outgoing emails

EMAIL_FROM_NAME=NayiBareilly
# Display name for outgoing emails

# ==========================================
# 7. REDIS CONFIGURATION (Optional but Recommended)
# ==========================================

# REDIS_URL=redis://localhost:6379
# Redis connection URL for token blacklist and caching
# Format: redis://username:password@host:port/database
# Example: redis://:password@localhost:6379/0

# REDIS_PASSWORD=your_redis_password
# Redis password (if authentication is enabled)

# REDIS_TLS=false
# Enable TLS for Redis connection

# ==========================================
# 8. RATE LIMITING CONFIGURATION
# ==========================================

# Global rate limits
RATE_LIMIT_WINDOW_MS=900000
# Rate limit window in milliseconds (default: 15 minutes)

RATE_LIMIT_MAX_REQUESTS=100
# Maximum requests per window for anonymous users

# Auth endpoint specific limits
LOGIN_RATE_LIMIT_MAX=5
# Maximum login attempts per window

REGISTER_RATE_LIMIT_MAX=3
# Maximum registration attempts per window

PASSWORD_RESET_RATE_LIMIT_MAX=3
# Maximum password reset requests per window

# ==========================================
# 9. FILE UPLOAD CONFIGURATION
# ==========================================

MAX_FILE_SIZE=5242880
# Maximum file size in bytes (default: 5MB = 5242880 bytes)

MAX_FILES_PER_UPLOAD=5
# Maximum number of files per upload

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
# Comma-separated list of allowed MIME types

# ==========================================
# 10. LOGGING CONFIGURATION
# ==========================================

LOG_LEVEL=info
# Logging level: error | warn | info | debug | verbose
# Production: warn or error
# Development: info or debug

LOG_FILE_PATH=./logs
# Directory for log files

LOG_MAX_SIZE=10485760
# Maximum log file size in bytes (default: 10MB)

LOG_MAX_FILES=5
# Maximum number of log files to keep

# ==========================================
# 11. CORS CONFIGURATION
# ==========================================

CORS_ORIGIN=http://localhost:3000
# Allowed CORS origins (comma-separated for multiple)
# Example: https://yourdomain.com,https://www.yourdomain.com

CORS_CREDENTIALS=true
# Allow credentials in CORS requests

# ==========================================
# 12. SESSION CONFIGURATION
# ==========================================

SESSION_SECRET=your_session_secret_key_minimum_32_characters
# Session encryption secret (if using express-session)

SESSION_MAX_AGE=86400000
# Session max age in milliseconds (default: 24 hours)

# ==========================================
# 13. SECURITY CONFIGURATION
# ==========================================

# Content Security Policy
CSP_ENABLED=true
# Enable Content Security Policy headers

# HTTP Strict Transport Security
HSTS_ENABLED=true
# Enable HSTS in production

HSTS_MAX_AGE=31536000
# HSTS max age in seconds (default: 1 year)

# Account Security
MAX_LOGIN_ATTEMPTS=5
# Maximum failed login attempts before account lock

ACCOUNT_LOCK_DURATION_MS=1800000
# Account lock duration in milliseconds (default: 30 minutes)

# ==========================================
# 14. ANALYTICS & MONITORING
# ==========================================

# ANALYTICS_ENABLED=true
# Enable analytics tracking

# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# Sentry error tracking DSN

# ==========================================
# 15. BACKUP CONFIGURATION
# ==========================================

# BACKUP_ENABLED=false
# Enable automatic backups

# BACKUP_SCHEDULE=0 2 * * *
# Backup cron schedule (default: daily at 2 AM)

# BACKUP_RETENTION_DAYS=7
# Number of days to retain backups

# ==========================================
# 16. FEATURE FLAGS
# ==========================================

ENABLE_ANONYMOUS_REPORTING=true
# Allow anonymous issue reporting

ENABLE_VOTING=true
# Enable upvote/downvote on issues

ENABLE_COMMENTS=true
# Enable comments on issues

ENABLE_EMAIL_NOTIFICATIONS=true
# Send email notifications

ENABLE_PUSH_NOTIFICATIONS=true
# Send push notifications via FCM

ENABLE_SMS_NOTIFICATIONS=false
# Send SMS notifications (requires additional setup)

ENABLE_AUTO_ESCALATION=true
# Automatically escalate issues based on SLA

# ==========================================
# 17. GEOLOCATION CONFIGURATION
# ==========================================

GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Google Maps API key for geocoding services

DEFAULT_CITY_LAT=28.367
# Default city center latitude (Bareilly)

DEFAULT_CITY_LNG=79.432
# Default city center longitude (Bareilly)

CITY_RADIUS_KM=50
# City radius for issue filtering (in kilometers)

# ==========================================
# 18. WEBHOOK CONFIGURATION (Optional)
# ==========================================

# WEBHOOK_URL=https://your-webhook-endpoint.com/webhook
# Webhook endpoint for external integrations

# WEBHOOK_SECRET=your_webhook_signing_secret
# Secret for webhook signature verification

# ==========================================
# 19. TWILIO CONFIGURATION (Optional - for SMS)
# ==========================================

# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# Twilio Account SID

# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio Auth Token

# TWILIO_PHONE_NUMBER=+1234567890
# Twilio phone number for sending SMS

# ==========================================
# 20. SCHEDULER CONFIGURATION
# ==========================================

ENABLE_SCHEDULER=true
# Enable background job scheduler

# SCHEDULER_CLEANUP_SCHEDULE=0 3 * * *
# Schedule for cleanup jobs (cron format)

# SCHEDULER_REPORT_SCHEDULE=0 8 * * 1
# Schedule for weekly reports (cron format)

# ==========================================
# 21. PERFORMANCE CONFIGURATION
# ==========================================

# Enable response compression
ENABLE_COMPRESSION=true

# Enable query result caching
ENABLE_CACHE=false

# Cache TTL in seconds
CACHE_TTL=300

# ==========================================
# 22. DEVELOPMENT TOOLS
# ==========================================

# Enable morgan HTTP logger in development
ENABLE_MORGAN=true

# Enable detailed error messages (disable in production)
ENABLE_DETAILED_ERRORS=true

# Enable Prisma Studio
# PRISMA_STUDIO_PORT=5555

# ==========================================
# 23. TESTING CONFIGURATION
# ==========================================

# TEST_DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/nayibareilly_test
# Test database URL (for running tests)

# TEST_JWT_SECRET=test_jwt_secret_for_unit_tests_only
# JWT secret for tests

# ==========================================
# NOTES:
# ==========================================
# 1. Generate secure JWT secrets:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Firebase Service Account:
#    - Get from Firebase Console > Project Settings > Service Accounts
#    - Either paste JSON here or save as firebase-service-account.json
#
# 3. Gmail App Password:
#    - Enable 2FA on your Gmail account
#    - Generate app password at: https://myaccount.google.com/apppasswords
#
# 4. Production checklist:
#    - Change NODE_ENV to 'production'
#    - Use strong, unique secrets (32+ characters)
#    - Enable HTTPS (handled by reverse proxy)
#    - Set secure CLIENT_ORIGIN
#    - Enable REDIS for token blacklist
#    - Configure proper email service
#    - Set up monitoring (Sentry)
#    - Configure automated backups
#
# 5. Security:
#    - NEVER commit .env file to git
#    - Use different secrets for each environment
#    - Rotate secrets periodically
#    - Use environment-specific configurations
#
# ==========================================
