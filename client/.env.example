# ================================================
# NayiBareilly Client Environment Configuration
# ================================================
# Copy this file to .env.local for development
# For production, set these in your hosting platform
# NEVER commit .env.local to version control!
# ================================================

# ==========================================
# 1. API CONFIGURATION
# ==========================================

NEXT_PUBLIC_API_URL=http://localhost:4001/api
# Backend API base URL
# Development: http://localhost:4001/api
# Production: https://api.yourdomain.com/api

NEXT_PUBLIC_WS_URL=http://localhost:4001
# WebSocket server URL for real-time updates
# Development: http://localhost:4001
# Production: https://api.yourdomain.com

# ==========================================
# 2. FIREBASE CLIENT CONFIGURATION
# ==========================================
# Get these from Firebase Console > Project Settings > General

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
# Firebase Web API Key

NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# Firebase Auth Domain

NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# Firebase Project ID

NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# Firebase Storage Bucket

NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
# Firebase Messaging Sender ID

NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
# Firebase App ID

NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Firebase Measurement ID (Google Analytics)

# Firebase Vapid Key (for push notifications)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_firebase_vapid_key
# Get from Firebase Console > Cloud Messaging > Web Push certificates

# ==========================================
# 3. GOOGLE MAPS CONFIGURATION
# ==========================================

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Google Maps JavaScript API Key
# Enable APIs: Maps JavaScript API, Geocoding API, Places API
# Get from: https://console.cloud.google.com/apis/credentials

NEXT_PUBLIC_DEFAULT_LAT=28.367
# Default map center latitude (Bareilly, Uttar Pradesh)

NEXT_PUBLIC_DEFAULT_LNG=79.432
# Default map center longitude (Bareilly, Uttar Pradesh)

NEXT_PUBLIC_DEFAULT_ZOOM=13
# Default map zoom level

# ==========================================
# 4. APPLICATION CONFIGURATION
# ==========================================

NEXT_PUBLIC_APP_NAME=NayiBareilly
# Application name (displayed in UI)

NEXT_PUBLIC_APP_DESCRIPTION=Empowering Citizens to Shape a Better Bareilly
# Application tagline/description

NEXT_PUBLIC_CITY_NAME=Bareilly
# City name for the platform

NEXT_PUBLIC_STATE_NAME=Uttar Pradesh
# State name

NEXT_PUBLIC_COUNTRY_CODE=IN
# Country code (ISO 3166-1 alpha-2)

# ==========================================
# 5. FEATURE FLAGS (PUBLIC)
# ==========================================

NEXT_PUBLIC_ENABLE_ANONYMOUS_REPORTING=true
# Allow anonymous issue reporting (true/false)

NEXT_PUBLIC_ENABLE_VOTING=true
# Enable upvote/downvote on issues (true/false)

NEXT_PUBLIC_ENABLE_COMMENTS=true
# Enable comments on issues (true/false)

NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
# Enable push notifications (true/false)

NEXT_PUBLIC_ENABLE_DARK_MODE=true
# Enable dark mode toggle (true/false)

NEXT_PUBLIC_ENABLE_MAP_VIEW=true
# Enable map view for issues (true/false)

NEXT_PUBLIC_ENABLE_IMAGE_UPLOAD=true
# Enable image uploads for issues (true/false)

NEXT_PUBLIC_MAX_IMAGES_PER_ISSUE=5
# Maximum images per issue

NEXT_PUBLIC_ENABLE_ANALYTICS=false
# Enable analytics tracking (true/false)

# ==========================================
# 6. UI CONFIGURATION
# ==========================================

NEXT_PUBLIC_THEME_PRIMARY_COLOR=#3b82f6
# Primary theme color (hex)

NEXT_PUBLIC_ITEMS_PER_PAGE=10
# Default items per page in lists

NEXT_PUBLIC_MAX_DESCRIPTION_LENGTH=2000
# Maximum characters for issue description

NEXT_PUBLIC_DEBOUNCE_DELAY_MS=300
# Debounce delay for search/input in milliseconds

# ==========================================
# 7. FILE UPLOAD CONFIGURATION
# ==========================================

NEXT_PUBLIC_MAX_FILE_SIZE_MB=5
# Maximum file size in megabytes

NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
# Comma-separated list of allowed MIME types

NEXT_PUBLIC_IMAGE_QUALITY=0.8
# Image compression quality (0-1)

# ==========================================
# 8. REAL-TIME CONFIGURATION
# ==========================================

NEXT_PUBLIC_ENABLE_REALTIME=true
# Enable real-time updates via WebSocket

NEXT_PUBLIC_WS_RECONNECT_INTERVAL_MS=5000
# WebSocket reconnection interval in milliseconds

NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=5
# Maximum WebSocket reconnection attempts

# ==========================================
# 9. GEOLOCATION CONFIGURATION
# ==========================================

NEXT_PUBLIC_ENABLE_GEOLOCATION=true
# Enable browser geolocation for issue reporting

NEXT_PUBLIC_GEOLOCATION_TIMEOUT_MS=10000
# Geolocation timeout in milliseconds

NEXT_PUBLIC_GEOLOCATION_MAX_AGE_MS=60000
# Maximum age of cached geolocation data

NEXT_PUBLIC_CITY_RADIUS_KM=50
# City radius for filtering issues (kilometers)

# ==========================================
# 10. NOTIFICATION CONFIGURATION
# ==========================================

NEXT_PUBLIC_NOTIFICATION_DURATION_MS=5000
# Toast notification duration in milliseconds

NEXT_PUBLIC_NOTIFICATION_POSITION=top-right
# Toast notification position (top-right, top-left, bottom-right, bottom-left)

NEXT_PUBLIC_ENABLE_SOUND_NOTIFICATIONS=false
# Enable sound for notifications

# ==========================================
# 11. PERFORMANCE CONFIGURATION
# ==========================================

NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true
# Enable Next.js image optimization

NEXT_PUBLIC_IMAGE_CACHE_TTL_SECONDS=31536000
# Image cache TTL in seconds (default: 1 year)

NEXT_PUBLIC_ENABLE_PREFETCH=true
# Enable link prefetching

NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true
# Enable service worker for offline support

# ==========================================
# 12. ANALYTICS & MONITORING
# ==========================================

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Analytics Measurement ID

# Sentry (Error Tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# Sentry DSN for client-side error tracking

# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Sentry environment name

# ==========================================
# 13. SEO CONFIGURATION
# ==========================================

NEXT_PUBLIC_SITE_URL=https://nayibareilly.gov.in
# Full site URL (used for meta tags, sitemap)
# Development: http://localhost:3000

NEXT_PUBLIC_SITE_TITLE=NayiBareilly - Citizen Grievance Platform
# Default page title

NEXT_PUBLIC_SITE_DESCRIPTION=Official citizen grievance redressal platform for Bareilly. Report civic issues, track progress, and build a better city together.
# Default meta description

NEXT_PUBLIC_OG_IMAGE=/og-image.jpg
# Default Open Graph image path

NEXT_PUBLIC_TWITTER_HANDLE=@NayiBareilly
# Twitter handle for Twitter Card meta tags

# ==========================================
# 14. CONTACT & SUPPORT
# ==========================================

NEXT_PUBLIC_SUPPORT_EMAIL=support@nayibareilly.gov.in
# Support email address

NEXT_PUBLIC_SUPPORT_PHONE=+91-1234567890
# Support phone number

NEXT_PUBLIC_HELPDESK_URL=https://help.nayibareilly.gov.in
# Helpdesk/documentation URL

# ==========================================
# 15. SOCIAL MEDIA LINKS
# ==========================================

NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/nayibareilly
# Facebook page URL

NEXT_PUBLIC_TWITTER_URL=https://twitter.com/nayibareilly
# Twitter profile URL

NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/nayibareilly
# Instagram profile URL

NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@nayibareilly
# YouTube channel URL

# ==========================================
# 16. AUTHENTICATION CONFIGURATION
# ==========================================

NEXT_PUBLIC_SESSION_TIMEOUT_MS=3600000
# Session timeout in milliseconds (default: 1 hour)

NEXT_PUBLIC_PASSWORD_MIN_LENGTH=8
# Minimum password length

NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=false
# Enable social login options

NEXT_PUBLIC_TOKEN_REFRESH_INTERVAL_MS=3300000
# Token refresh interval in milliseconds (default: 55 minutes)

# ==========================================
# 17. ISSUE CATEGORIES
# ==========================================

NEXT_PUBLIC_DEFAULT_CATEGORY=general
# Default issue category

# Available categories (comma-separated)
NEXT_PUBLIC_ISSUE_CATEGORIES=roads,water,electricity,garbage,drainage,street-lights,parks,pollution,public-transport,health,education,general

# ==========================================
# 18. SLA CONFIGURATION (Display Only)
# ==========================================

NEXT_PUBLIC_SLA_CRITICAL_HOURS=24
# SLA for critical issues (hours)

NEXT_PUBLIC_SLA_HIGH_HOURS=72
# SLA for high priority issues (hours)

NEXT_PUBLIC_SLA_MEDIUM_HOURS=168
# SLA for medium priority issues (hours)

NEXT_PUBLIC_SLA_LOW_HOURS=720
# SLA for low priority issues (hours)

# ==========================================
# 19. RATE LIMITING (CLIENT-SIDE)
# ==========================================

NEXT_PUBLIC_API_THROTTLE_MS=1000
# Minimum time between API calls (milliseconds)

NEXT_PUBLIC_SEARCH_DEBOUNCE_MS=500
# Search input debounce delay (milliseconds)

# ==========================================
# 20. DEVELOPMENT TOOLS
# ==========================================

# Development mode
# NEXT_PUBLIC_DEBUG_MODE=false
# Enable debug logging in browser console

# NEXT_PUBLIC_MOCK_API=false
# Use mock API responses (for development/testing)

# NEXT_PUBLIC_SHOW_DEV_TOOLS=false
# Show developer tools panel

# ==========================================
# 21. LOCALIZATION
# ==========================================

NEXT_PUBLIC_DEFAULT_LOCALE=en
# Default language (en, hi)

NEXT_PUBLIC_AVAILABLE_LOCALES=en,hi
# Comma-separated list of supported locales

NEXT_PUBLIC_ENABLE_RTL=false
# Enable right-to-left text direction

# ==========================================
# 22. ACCESSIBILITY
# ==========================================

NEXT_PUBLIC_ENABLE_KEYBOARD_SHORTCUTS=true
# Enable keyboard shortcuts

NEXT_PUBLIC_HIGH_CONTRAST_MODE=false
# Enable high contrast mode by default

NEXT_PUBLIC_FONT_SIZE_SCALE=1.0
# Default font size scale (1.0 = normal)

# ==========================================
# 23. PROGRESSIVE WEB APP (PWA)
# ==========================================

NEXT_PUBLIC_PWA_ENABLED=true
# Enable PWA features

NEXT_PUBLIC_PWA_START_URL=/
# PWA start URL

NEXT_PUBLIC_PWA_THEME_COLOR=#3b82f6
# PWA theme color

NEXT_PUBLIC_PWA_BACKGROUND_COLOR=#ffffff
# PWA background color

# ==========================================
# 24. CACHE CONFIGURATION
# ==========================================

NEXT_PUBLIC_API_CACHE_TIME_MS=300000
# API response cache time in milliseconds (default: 5 minutes)

NEXT_PUBLIC_STATIC_CACHE_TIME_SECONDS=86400
# Static asset cache time in seconds (default: 24 hours)

# ==========================================
# 25. SECURITY HEADERS (META)
# ==========================================

NEXT_PUBLIC_CSP_REPORT_URI=https://your-domain.com/api/csp-report
# Content Security Policy report URI

# ==========================================
# NOTES:
# ==========================================
# 1. Environment File Priority in Next.js:
#    - .env.local (highest priority, not committed)
#    - .env.production (for production builds)
#    - .env.development (for development)
#    - .env (lowest priority)
#
# 2. NEXT_PUBLIC_ prefix:
#    - Required for variables accessible in browser
#    - Variables without prefix are server-side only
#    - Never put secrets in NEXT_PUBLIC_ variables!
#
# 3. Firebase Setup:
#    - Get config from Firebase Console > Project Settings
#    - Enable Authentication, Storage, Cloud Messaging
#    - Configure authorized domains
#
# 4. Google Maps Setup:
#    - Create API key at Google Cloud Console
#    - Enable: Maps JavaScript API, Geocoding API, Places API
#    - Restrict key to your domain for production
#
# 5. Production Checklist:
#    - Update all URLs to production domains
#    - Use production Firebase config
#    - Configure proper API keys with domain restrictions
#    - Enable analytics and monitoring
#    - Set secure CSP and security headers
#    - Test PWA manifest and service worker
#
# 6. Development:
#    - Copy this file to .env.local
#    - Fill in development values
#    - Restart Next.js dev server after changes
#
# 7. Vercel Deployment:
#    - Add all variables in Vercel dashboard
#    - Use different values for preview vs production
#    - Environment variables are encrypted at rest
#
# 8. Security:
#    - NEVER commit .env.local to git
#    - Don't put secrets in NEXT_PUBLIC_ variables
#    - Use environment-specific configurations
#    - Rotate API keys periodically
#
# ==========================================
