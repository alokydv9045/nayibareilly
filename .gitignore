# ================================
# Nagarsetu Multi-Service Project
# ================================

# Dependencies
**/node_modules/
# Commit package-lock.json for production deployments
# **/package-lock.json

# Environment Variables (CRITICAL - Never commit actual .env files!)
# Only commit .env.example files as templates
# Ignore all .env files
**/.env
**/.env.local
**/.env.*.local
**/.env.development
**/.env.development.local
**/.env.production
**/.env.production.local
**/.env.test
**/.env.test.local
# Exception: Allow all .env.example files to be committed
!**/.env.example
!**/.env*.example

# ================================
# CLIENT (Next.js) SPECIFIC
# ================================
client/.next/
client/out/
client/build/
client/dist/
client/.turbo/
client/.swc/
client/next-env.d.ts
client/*.tsbuildinfo

# ================================
# SERVER & ADMIN-SERVER SPECIFIC
# ================================
server/dist/
server/build/
admin-server/dist/
admin-server/build/

# Uploads (keep structure)
**/uploads/*
!**/uploads/.gitkeep

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/lerna-debug.log*
**/pnpm-debug.log*

# ================================
# DEVELOPMENT & BUILD ARTIFACTS
# ================================
# Coverage reports
**/coverage/
**/.nyc_output/

# Runtime data
**/pids/
**/*.pid
**/tmp/
**/temp/

# Cache directories
**/.cache/
**/.parcel-cache/
**/.eslintcache
**/.stylelintcache

# Optional npm cache directory
**/.npm

# Optional REPL history
**/.node_repl_history

# ================================
# DATABASE & STORAGE
# ================================
# Database files
**/*.sqlite
**/*.sqlite3
**/*.db

# Prisma
**/prisma/migrations/
**/prisma/.env
# Don't ignore the schema - it's needed for the database
!**/prisma/schema.prisma
!**/prisma/seed.ts
!**/prisma/seed.js

